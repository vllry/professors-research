# Development Dockerfile for API server
FROM golang:1.23.2-alpine

# Install build dependencies and air for hot reload
RUN apk add --no-cache git ca-certificates tzdata curl wget

# Install air for hot reload (pinned to version compatible with Go 1.23.2)
RUN go install github.com/cosmtrek/air@v1.51.0

# Set working directory
WORKDIR /app

# Copy go mod files first for better caching
COPY go.mod go.sum ./

# Download dependencies
RUN go mod download

# Copy source code
COPY . .

# Expose the default port
EXPOSE 8080

# Use air for hot reload in development
# Air will watch for changes and rebuild automatically
CMD ["air", "-c", ".air.toml"]

